def read_employees():
    global employees

    employees = {
        "fields": [],
        "rows": []
    }

    try:
        with open("../csv/employees.csv", "r") as file:
            reader = csv.reader(file)

            first = True
            for row in reader:
                if first:
                    employees["fields"] = row
                    first = False
                else:
                    employees["rows"].append(row)

    except Exception as e:
        print("Exception type:", type(e).__name__)
        print("Exception message:", str(e))
        traceback.print_exc()
        exit()

    return employees


