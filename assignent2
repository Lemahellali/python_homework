def read_minutes():

    def load(file_path):
        data = {"fields": [], "rows": []}

        with open(file_path, "r") as file:
            reader = csv.reader(file)

            first = True
            for row in reader:
                if first:
                    data["fields"] = row
                    first = False
                else:
                    data["rows"].append(tuple(row))  # IMPORTANT

        return data

    m1 = load("../csv/minutes1.csv")
    m2 = load("../csv/minutes2.csv")

    return m1, m2


