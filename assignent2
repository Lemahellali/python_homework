def write_sorted_list():
    global minutes_list

    minutes_list.sort(key=lambda x: x[1])

    converted = list(map(
        lambda x: (
            x[0],
            datetime.strftime(x[1], "%B %d, %Y")
        ),
        minutes_list
    ))

    with open("./minutes.csv", "w", newline="") as file:
        writer = csv.writer(file)

        writer.writerow(minutes1["fields"])

        for row in converted:
            writer.writerow(row)

    return converted


